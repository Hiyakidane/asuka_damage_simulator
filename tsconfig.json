{
    "compilerOptions": {
      "module": "commonjs",
      "target": "es2015",
      "sourceMap": true,
      "outDir": "dist",
      "jsx": "react",
      "esModuleInterop": true,
    },
    "exclude": [
      "node_modules"
    ],
    "include": [
      "src/**/*.ts",
      "src/**/*.tsx",
      "src/**/*.js",
      "src/**/*.jsx"
    ]
  }